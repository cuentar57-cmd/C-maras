<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Cámaras de Motos</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #0d0d0d; color: #f0f0f0; font-family: 'Courier New', monospace; min-height: 100vh; }

header {
background: #111; border-bottom: 2px solid #ff4500;
padding: 18px 28px; display: flex; align-items: center;
justify-content: space-between; flex-wrap: wrap; gap: 12px;
}
.header-title .sub { font-size: 10px; color: #ff4500; letter-spacing: 4px; margin-bottom: 4px; }
.header-title .main { font-size: 20px; font-weight: bold; letter-spacing: 2px; }
.tab-btns { display: flex; gap: 10px; }
.tab-btn {
background: transparent; border: 1.5px solid #444; color: #aaa;
padding: 8px 18px; cursor: pointer; font-size: 11px; letter-spacing: 2px;
font-family: inherit; border-radius: 2px; transition: all .2s;
}
.tab-btn.active { background: #ff4500; border-color: #ff4500; color: #fff; }

.stats-bar {
background: #161616; border-bottom: 1px solid #222;
padding: 14px 28px; display: flex; gap: 32px; flex-wrap: wrap;
}
.stat .slabel { font-size: 10px; color: #555; letter-spacing: 2px; margin-bottom: 3px; }
.stat .sval { font-size: 22px; font-weight: bold; color: #ff4500; }

.container { max-width: 700px; margin: 0 auto; padding: 28px; }

.card {
background: #161616; border: 1px solid #2a2a2a;
border-top: 3px solid #ff4500; border-radius: 4px; padding: 28px;
}
.card-title { font-size: 11px; color: #ff4500; letter-spacing: 3px; margin-bottom: 20px; }

label { display: block; font-size: 10px; color: #666; letter-spacing: 3px; margin-bottom: 8px; margin-top: 20px; }
label:first-of-type { margin-top: 0; }
input[type=date], input[type=number], textarea {
width: 100%; background: #0d0d0d; border: 1px solid #2a2a2a;
border-radius: 2px; color: #f0f0f0; padding: 12px 14px;
font-size: 14px; font-family: ‘Courier New’, monospace; outline: none;
}
input[type=date]::-webkit-calendar-picker-indicator { filter: invert(1) opacity(.4); }
textarea { resize: vertical; line-height: 1.5; }
input:focus, textarea:focus { border-color: #ff4500; }

.btn-row { display: flex; gap: 12px; margin-top: 18px; }
.btn-save {
flex: 1; background: #ff4500; border: none; color: #fff;
padding: 14px; font-size: 12px; font-family: inherit; letter-spacing: 3px;
cursor: pointer; border-radius: 2px; font-weight: bold;
}
.btn-save:disabled { background: #333; cursor: not-allowed; }
.btn-cancel {
background: transparent; border: 1.5px solid #444; color: #aaa;
padding: 14px 20px; cursor: pointer; font-family: inherit;
font-size: 11px; border-radius: 2px;
}

.section-title { font-size: 11px; color: #555; letter-spacing: 3px; margin-bottom: 14px; margin-top: 28px; }

.record {
background: #161616; border: 1px solid #222; border-left: 3px solid #ff4500;
border-radius: 2px; padding: 16px 20px; margin-bottom: 10px;
display: flex; align-items: center; justify-content: space-between;
gap: 12px; flex-wrap: wrap;
}
.record .rdate { font-size: 13px; font-weight: bold; letter-spacing: 1px; }
.record .rnote { font-size: 11px; color: #666; margin-top: 4px; }
.record .rupdated { font-size: 10px; color: #383838; margin-top: 4px; }
.record .rcount { font-size: 28px; font-weight: bold; color: #ff4500; line-height: 1; }
.record .rcountlabel { font-size: 10px; color: #555; letter-spacing: 1px; }
.record-right { display: flex; align-items: center; gap: 18px; }
.record-actions { display: flex; gap: 8px; }
.btn-icon {
width: 32px; height: 32px; border: none; cursor: pointer;
font-size: 13px; border-radius: 2px; display: flex;
align-items: center; justify-content: center;
}
.btn-edit { background: #2a2a2a; color: #aaa; }
.btn-del { background: #2a0000; color: #ff6644; }

.view-all { background: none; border: none; color: #ff4500; cursor: pointer; font-size: 11px; font-family: inherit; letter-spacing: 2px; margin-top: 8px; }
.empty { color: #444; padding: 60px; text-align: center; font-size: 13px; line-height: 2; }
.empty a { color: #ff4500; cursor: pointer; text-decoration: none; }

#toast {
display: none; position: fixed; bottom: 28px; right: 28px;
padding: 14px 22px; border-radius: 4px; font-size: 13px; letter-spacing: 1px;
z-index: 999; animation: fadeIn .2s ease;
}
#toast.ok { background: #1a3a1a; border: 1px solid #2d7a2d; color: #fff; }
#toast.err { background: #7a1a00; border: 1px solid #ff4500; color: #fff; }
@keyframes fadeIn { from { opacity:0; transform:translateY(8px) } to { opacity:1; } }

.loading { color: #555; padding: 40px; text-align: center; }
</style>

</head>
<body>

<header>
  <div class="header-title">
    <div class="sub">SISTEMA DE CONTROL</div>
    <div class="main">🏍 CÁMARAS DE MOTOS</div>
  </div>
  <div class="tab-btns">
    <button class="tab-btn active" onclick="setView('register')">CARGAR</button>
    <button class="tab-btn" onclick="setView('history')">HISTORIAL</button>
  </div>
</header>

<div class="stats-bar">
  <div class="stat"><div class="slabel">DÍAS REGISTRADOS</div><div class="sval" id="sDias">0</div></div>
  <div class="stat"><div class="slabel">TOTAL CÁMARAS</div><div class="sval" id="sTotal">0</div></div>
  <div class="stat"><div class="slabel">PROMEDIO/DÍA</div><div class="sval" id="sProm">0</div></div>
  <div class="stat"><div class="slabel">MÁXIMO</div><div class="sval" id="sMax">0</div></div>
</div>

<div class="container">
  <!-- REGISTER VIEW -->
  <div id="viewRegister">
    <div class="card">
      <div class="card-title" id="formTitle">▶ NUEVO REGISTRO</div>

```
  <label>FECHA</label>
  <input type="date" id="inDate"/>

  <label>CANTIDAD DE CÁMARAS</label>
  <input type="number" id="inCount" min="0" placeholder="Ej: 42"/>

  <label>OBSERVACIONES (opcional)</label>
  <textarea id="inNote" rows="3" placeholder="Notas del día..."></textarea>

  <div class="btn-row">
    <button class="btn-save" id="btnSave" onclick="handleSave()">GUARDAR</button>
    <button class="btn-cancel" id="btnCancel" style="display:none" onclick="cancelEdit()">CANCELAR</button>
  </div>
</div>

<div id="previewSection" style="display:none">
  <div class="section-title">ÚLTIMOS REGISTROS</div>
  <div id="previewList"></div>
  <button class="view-all" id="btnViewAll" onclick="setView('history')">VER TODO EL HISTORIAL →</button>
</div>
```

  </div>

  <!-- HISTORY VIEW -->

  <div id="viewHistory" style="display:none">
    <div class="section-title" id="histCount">0 REGISTROS GUARDADOS</div>
    <div id="historyList"><div class="loading">Cargando...</div></div>
  </div>
</div>

<div id="toast"></div>

<script>
const SHARED = true;
let records = [];
let editingId = null;
let currentView = 'register';

function today() {
  return new Date().toISOString().split('T')[0];
}
function formatDate(d) {
  const [y,m,day] = d.split('-');
  return `${day}/${m}/${y}`;
}

async function loadRecords() {
  try {
    const result = await window.storage.list('cam:', SHARED);
    if (!result || !result.keys || result.keys.length === 0) {
      records = [];
    } else {
      const items = [];
      for (const key of result.keys) {
        try {
          const r = await window.storage.get(key, SHARED);
          if (r) items.push(JSON.parse(r.value));
        } catch {}
      }
      items.sort((a,b) => b.date.localeCompare(a.date));
      records = items;
    }
  } catch {
    records = [];
  }
  updateStats();
  renderCurrent();
}

function updateStats() {
  const total = records.reduce((s,r) => s+r.count, 0);
  const max = records.length ? Math.max(...records.map(r=>r.count)) : 0;
  const prom = records.length ? Math.round(total/records.length) : 0;
  document.getElementById('sDias').textContent = records.length;
  document.getElementById('sTotal').textContent = total;
  document.getElementById('sProm').textContent = prom;
  document.getElementById('sMax').textContent = max;
}

function renderCurrent() {
  if (currentView === 'register') renderPreview();
  else renderHistory();
}

function renderPreview() {
  const section = document.getElementById('previewSection');
  const list = document.getElementById('previewList');
  const btnAll = document.getElementById('btnViewAll');
  if (records.length === 0) { section.style.display='none'; return; }
  section.style.display='block';
  btnAll.style.display = records.length > 3 ? 'block' : 'none';
  list.innerHTML = records.slice(0,3).map(r => recordHTML(r, false)).join('');
}

function renderHistory() {
  const list = document.getElementById('historyList');
  const cnt = document.getElementById('histCount');
  cnt.textContent = records.length + ' REGISTROS GUARDADOS';
  if (records.length === 0) {
    list.innerHTML = `<div class="empty">No hay registros aún.<br><a onclick="setView('register')">Cargar el primero →</a></div>`;
    return;
  }
  list.innerHTML = records.map(r => recordHTML(r, true)).join('');
}

function recordHTML(r, expanded) {
  const note = expanded && r.note ? `<div class="rnote">${r.note}</div>` : '';
  const upd = expanded && r.updatedAt ? `<div class="rupdated">actualizado: ${new Date(r.updatedAt).toLocaleString('es-AR')}</div>` : '';
  return `
    <div class="record">
      <div>
        <div class="rdate">${formatDate(r.date)}</div>
        ${note}${upd}
      </div>
      <div class="record-right">
        <div style="text-align:right">
          <div class="rcount">${r.count}</div>
          <div class="rcountlabel">CÁMARAS</div>
        </div>
        <div class="record-actions">
          <button class="btn-icon btn-edit" onclick='startEdit(${JSON.stringify(r)})'>✏</button>
          <button class="btn-icon btn-del" onclick="handleDelete('${r.id}')">✕</button>
        </div>
      </div>
    </div>`;
}

function setView(v) {
  currentView = v;
  document.getElementById('viewRegister').style.display = v==='register' ? 'block' : 'none';
  document.getElementById('viewHistory').style.display = v==='history' ? 'block' : 'none';
  document.querySelectorAll('.tab-btn').forEach((b,i) => {
    b.classList.toggle('active', (i===0&&v==='register')||(i===1&&v==='history'));
  });
  renderCurrent();
}

function startEdit(r) {
  editingId = r.id;
  document.getElementById('inDate').value = r.date;
  document.getElementById('inCount').value = r.count;
  document.getElementById('inNote').value = r.note || '';
  document.getElementById('formTitle').textContent = '✏ EDITANDO REGISTRO';
  document.getElementById('btnSave').textContent = 'ACTUALIZAR';
  document.getElementById('btnCancel').style.display = 'block';
  setView('register');
  window.scrollTo({top:0, behavior:'smooth'});
}

function cancelEdit() {
  editingId = null;
  document.getElementById('inDate').value = today();
  document.getElementById('inCount').value = '';
  document.getElementById('inNote').value = '';
  document.getElementById('formTitle').textContent = '▶ NUEVO REGISTRO';
  document.getElementById('btnSave').textContent = 'GUARDAR';
  document.getElementById('btnCancel').style.display = 'none';
}

async function handleSave() {
  const date = document.getElementById('inDate').value;
  const count = document.getElementById('inCount').value;
  const note = document.getElementById('inNote').value.trim();
  if (!date || count==='' || isNaN(Number(count)) || Number(count)<0) {
    showToast('Completá la fecha y la cantidad.','err'); return;
  }
  const btn = document.getElementById('btnSave');
  btn.disabled = true; btn.textContent = 'GUARDANDO...';
  const key = 'cam:' + date;
  const record = { id: key, date, count: Number(count), note, updatedAt: new Date().toISOString() };
  try {
    await window.storage.set(key, JSON.stringify(record), SHARED);
    showToast('✓ Guardado correctamente');
    cancelEdit();
    await loadRecords();
  } catch {
    showToast('Error al guardar. Intentá de nuevo.','err');
  }
  btn.disabled = false;
  btn.textContent = editingId ? 'ACTUALIZAR' : 'GUARDAR';
}

async function handleDelete(key) {
  if (!confirm('¿Eliminar este registro?')) return;
  try {
    await window.storage.delete(key, SHARED);
    showToast('Registro eliminado');
    await loadRecords();
  } catch {
    showToast('Error al eliminar.','err');
  }
}

let toastTimer;
function showToast(msg, type='ok') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = type;
  t.style.display = 'block';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => { t.style.display='none'; }, 2800);
}

// Init
document.getElementById('inDate').value = today();
loadRecords();
</script>

</body>
</html>
